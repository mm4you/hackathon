DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/innovatex_smart_port?schema=public"
JWT_SECRET="replace-with-at-least-32-characters-in-production"

# Optional. Only set this to true when intentionally seeding a demo/staging database.
# Localhost databases are allowed without this flag.
ALLOW_DEMO_SEED="false"

# Optional LLM advisor. If unset, recommendation uses the local heuristic engine only.
LLM_API_KEY=""
LLM_BASE_URL="https://openrouter.ai/api/v1"
LLM_MODEL="openai/gpt-oss-20b:free"

# Optional realtime traffic. TomTom has a free/freemium developer tier.
# If unset, booking uses simulation traffic so the demo still works.
TOMTOM_API_KEY=""
